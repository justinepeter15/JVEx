{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with subscription state",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "isPremium": { "type": "boolean" },
        "subscriptionExpiresAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "isPremium", "createdAt"]
    },
    "Resource": {
      "title": "Resource",
      "description": "Learning resource like exams, books, lesson plans",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "type": { "type": "string", "enum": ["exam", "book", "lesson_plan", "other"] },
        "category": { "type": "string" },
        "isPremium": { "type": "boolean" },
        "fileUrl": { "type": "string", "format": "uri" },
        "thumbnailUrl": { "type": "string", "format": "uri" },
        "authorId": { "type": "string" },
        "downloadCount": { "type": "integer" },
        "averageRating": { "type": "number" },
        "reviewCount": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "type", "isPremium", "fileUrl", "createdAt"]
    },
    "Review": {
      "title": "Review",
      "description": "User review and rating for a resource",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "rating": { "type": "integer" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "rating", "comment", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile and subscription data"
    },
    "/resources/{resourceId}": {
      "schema": "Resource",
      "description": "Metadata for learning resources"
    },
    "/resources/{resourceId}/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Reviews for a specific resource"
    }
  }
}
